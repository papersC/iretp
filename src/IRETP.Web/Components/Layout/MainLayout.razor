@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject UiStateService Ui
@inject LocalizationService T
@inject CurrencyService Currency
@inject NotificationFeedService Feed
@implements IDisposable

<!-- Skip link for keyboard users (WCAG 2.4.1) -->
<a class="iretp-skip-link" href="#iretp-main">Skip to main content</a>

<!-- ===== LOGO BANNER ===== -->
<div class="logo-banner">
    <a href="/" class="d-flex align-items-center text-decoration-none">
        <img src="images/logos/gov-dubai-logo.png" alt="Government of Dubai" class="gov-logo" style="width:150px;height:auto;" />
    </a>
    <a href="/" class="d-flex align-items-center text-decoration-none">
        <img src="images/logos/dld-logo.png" alt="Dubai Land Department" class="dld-logo" style="height:42px;width:auto;" />
    </a>
</div>

<!-- ===== TOP TOOLBAR ===== -->
<header class="top-toolbar" role="banner">
    <div class="d-flex align-items-center gap-3">
        <button class="btn btn-sm btn-light" @onclick="ToggleSidebar"
                aria-label="Toggle navigation sidebar" aria-controls="app-sidebar">
            <i class="bi bi-list fs-5" aria-hidden="true"></i>
        </button>
        <a href="/" class="app-brand" aria-label="IRETP home">
            <div class="brand-icon"><i class="bi bi-building" aria-hidden="true"></i></div>
            <span class="d-none d-md-inline">IRETP</span>
        </a>
    </div>
    <div class="d-flex align-items-center gap-2">
        <HeaderWidgets @rendermode="InteractiveServer" />
    </div>
</header>

<!-- ===== SIDEBAR OVERLAY (mobile) ===== -->
<div id="sidebarOverlay" class="sidebar-overlay" @onclick="CloseSidebar"></div>

<!-- ===== SIDEBAR ===== -->
<nav id="app-sidebar" class="sidebar d-flex flex-column">
    <div class="flex-grow-1 py-3">

        @* ===== AUDIENCE: Public (open to anyone, no sign-in) ===== *@
        <div class="section-title nav-audience">@T["nav.areaPublic"]</div>

        <a href="/" class="sidebar-nav-link @NavActive("/")">
            <i class="bi bi-speedometer2"></i><span class="nav-label">@T["nav.dashboard"]</span>
        </a>

        @* Market Data — the core transactional figures investors hit most. *@
        <details class="nav-section" open="@MarketOpen">
            <summary class="section-title">
                <span>@T["nav.marketData"]</span><i class="bi bi-chevron-right chevron"></i>
            </summary>
            <a href="/map" class="sidebar-nav-link @NavActive("/map")">
                <i class="bi bi-map"></i><span class="nav-label">@T["nav.map"]</span>
            </a>
            <a href="/transactions" class="sidebar-nav-link @NavActive("/transactions")">
                <i class="bi bi-receipt"></i><span class="nav-label">@T["nav.transactions"]</span>
            </a>
            <a href="/price-index" class="sidebar-nav-link @NavActive("/price-index")">
                <i class="bi bi-graph-up-arrow"></i><span class="nav-label">@T["nav.priceIndex"]</span>
            </a>
            <a href="/rental-index" class="sidebar-nav-link @NavActive("/rental-index")">
                <i class="bi bi-house"></i><span class="nav-label">@T["nav.rentalIndex"]</span>
            </a>
            <a href="/mortgage" class="sidebar-nav-link @NavActive("/mortgage")">
                <i class="bi bi-bank"></i><span class="nav-label">@T["nav.mortgage"]</span>
            </a>
        </details>

        @* Projects & Developers — the supply-side entities and who's behind them. *@
        <details class="nav-section" open="@EntitiesOpen">
            <summary class="section-title">
                <span>@T["nav.entities"]</span><i class="bi bi-chevron-right chevron"></i>
            </summary>
            <a href="/projects" class="sidebar-nav-link @NavActive("/projects")">
                <i class="bi bi-buildings"></i><span class="nav-label">@T["nav.projects"]</span>
            </a>
            <a href="/developers" class="sidebar-nav-link @NavActive("/developers")">
                <i class="bi bi-person-badge"></i><span class="nav-label">@T["nav.developers"]</span>
            </a>
            <a href="/developers/scorecards" class="sidebar-nav-link @NavActive("/developers/scorecards")">
                <i class="bi bi-award"></i><span class="nav-label">@T["nav.scorecards"]</span>
            </a>
            <a href="/beneficial-ownership" class="sidebar-nav-link @NavActive("/beneficial-ownership")">
                <i class="bi bi-diagram-3"></i><span class="nav-label">@T["nav.beneficialOwnership"]</span>
            </a>
        </details>

        @* Insights & Analytics — derived intelligence on top of the raw market data. *@
        <details class="nav-section" open="@InsightsOpen">
            <summary class="section-title">
                <span>@T["nav.insights"]</span><i class="bi bi-chevron-right chevron"></i>
            </summary>
            <a href="/analytics" class="sidebar-nav-link @NavActive("/analytics")">
                <i class="bi bi-bar-chart-line"></i><span class="nav-label">@T["nav.analytics"]</span>
            </a>
            <a href="/analytics/compare" class="sidebar-nav-link @NavActive("/analytics/compare")">
                <i class="bi bi-bar-chart-steps"></i><span class="nav-label">@T["nav.compare"]</span>
            </a>
            <a href="/benchmark" class="sidebar-nav-link @NavActive("/benchmark")">
                <i class="bi bi-globe2"></i><span class="nav-label">@T["nav.benchmark"]</span>
            </a>
            <a href="/esg" class="sidebar-nav-link @NavActive("/esg")">
                <i class="bi bi-tree"></i><span class="nav-label">@T["nav.esg"]</span>
            </a>
            <a href="/greti" class="sidebar-nav-link @NavActive("/greti")">
                <i class="bi bi-trophy-fill"></i><span class="nav-label">@T["nav.greti"]</span>
            </a>
        </details>

        @* Tools & Data — cross-cutting ways to query the platform (AI + programmatic). *@
        <details class="nav-section" open="@ToolsOpen">
            <summary class="section-title">
                <span>@T["nav.toolsData"]</span><i class="bi bi-chevron-right chevron"></i>
            </summary>
            <a href="/ai-agent" class="sidebar-nav-link @NavActive("/ai-agent")">
                <i class="bi bi-robot"></i><span class="nav-label">@T["nav.aiAgent"]</span>
            </a>
            <a href="/api-portal" class="sidebar-nav-link @NavActive("/api-portal")">
                <i class="bi bi-code-slash"></i><span class="nav-label">@T["nav.apiPortal"]</span>
            </a>
        </details>

        @* ===== AUDIENCE: Investor (requires sign-in; personal saved surfaces) ===== *@
        <div class="section-title nav-audience">@T["nav.areaInvestor"]</div>

        <a href="/watchlist" class="sidebar-nav-link @NavActive("/watchlist")">
            <i class="bi bi-bookmark-star"></i><span class="nav-label">@T["nav.watchlist"]</span>
        </a>
        <a href="/alerts" class="sidebar-nav-link @NavActive("/alerts")">
            <i class="bi bi-bell"></i><span class="nav-label">@T["nav.alerts"]</span>
        </a>
        <a href="/notifications" class="sidebar-nav-link @NavActive("/notifications")">
            <i class="bi bi-inbox"></i><span class="nav-label">@T["nav.notifications"]</span>
        </a>

        @* ===== AUDIENCE: Administration (staff only) =====
           Direct entries to the high-traffic admin surfaces, grouped by function.
           The hub (/admin) sits at the bottom as a catch-all for tools that have
           no dedicated sidebar entry — nothing here is duplicated there. *@
        <div class="section-title nav-audience">@T["nav.admin"]</div>

        @* Risk & Compliance — EWRS, escrow, audit. *@
        <details class="nav-section" open="@AdminRiskOpen">
            <summary class="section-title">
                <span>@T["nav.adminRisk"]</span><i class="bi bi-chevron-right chevron"></i>
            </summary>
            <a href="/admin/ewrs" class="sidebar-nav-link @NavActive("/admin/ewrs")">
                <i class="bi bi-bell"></i><span class="nav-label">@T["nav.ewrs"]</span>
            </a>
            <a href="/admin/ewrs/alerts" class="sidebar-nav-link @NavActive("/admin/ewrs/alerts")">
                <i class="bi bi-list-check"></i><span class="nav-label">@T["nav.ewrsAlerts"]</span>
            </a>
            <a href="/admin/escrow" class="sidebar-nav-link @NavActive("/admin/escrow")">
                <i class="bi bi-bank"></i><span class="nav-label">@T["nav.escrow"]</span>
            </a>
            <a href="/admin/audit" class="sidebar-nav-link @NavActive("/admin/audit")">
                <i class="bi bi-clipboard-data"></i><span class="nav-label">@T["nav.audit"]</span>
            </a>
        </details>

        @* Developer Oversight — ratings + content governance. *@
        <details class="nav-section" open="@AdminDevOpen">
            <summary class="section-title">
                <span>@T["nav.adminDev"]</span><i class="bi bi-chevron-right chevron"></i>
            </summary>
            <a href="/admin/developers" class="sidebar-nav-link @NavActive("/admin/developers")">
                <i class="bi bi-people"></i><span class="nav-label">@T["nav.developerRating"]</span>
            </a>
            <a href="/admin/cms" class="sidebar-nav-link @NavActive("/admin/cms")">
                <i class="bi bi-file-earmark-text"></i><span class="nav-label">@T["nav.cms"]</span>
            </a>
        </details>

        @* Hub sits at the bottom of the section — a catch-all for the admin tools
           that have no dedicated sidebar entry (EWRS playbooks, developer
           comparison, AI models, Fabric/OneLake), reached as tabs inside it. *@
        <a href="/admin" class="sidebar-nav-link @NavActive("/admin")">
            <i class="bi bi-grid-1x2"></i><span class="nav-label">@T["nav.adminHub"]</span>
        </a>
    </div>

    <div class="sidebar-footer">
        <div>IRETP v1.0</div>
        <div>&copy; 2026 Dubai Land Department</div>
    </div>
</nav>

<!-- ===== MAIN CONTENT ===== -->
<main id="iretp-main" class="main-content" role="main" tabindex="-1">
    @Body
</main>

<!-- Organization structured data (GRETI Market Fundamentals sub-index signal) -->
<IRETP.Web.Components.Shared.StructuredData Type="GovernmentOrganization" Data="@OrganizationSchema" />

<footer class="site-footer" style="margin-left: var(--sidebar-width);">
    <div class="container-fluid text-center">
        <div class="d-flex flex-wrap justify-content-center align-items-center gap-3">
            <span>&copy; 2026 Dubai Land Department</span>
            <span class="d-none d-md-inline">|</span>
            <span class="d-none d-md-inline">Integrated Real Estate Transparency Platform</span>
        </div>
    </div>
</footer>

<BackToTop @rendermode="InteractiveServer" />

<FloatingAiLauncher @rendermode="InteractiveServer" />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#10005;</span>
</div>

@code {
    private string _currentPath = "/";

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        Ui.OnChange += HandleUiChange;
        _currentPath = new Uri(Nav.Uri).AbsolutePath;
        _activeHref = ComputeActiveHref();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentPath = new Uri(e.Location).AbsolutePath;
        _activeHref = ComputeActiveHref();
        InvokeAsync(StateHasChanged);
    }

    private void HandleUiChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Ui.OnChange -= HandleUiChange;
    }

    // A link is "active" only when it is the single most-specific match for the
    // current path. Resolving the best match (longest matching href) up-front
    // avoids the old prefix bug where, e.g., /analytics stayed highlighted on
    // /analytics/compare, or the admin hub lit up across the whole /admin/* area.
    private string NavActive(string href) =>
        string.Equals(href, _activeHref, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    // Accordion sidebar: a collapsible group is expanded only when the current
    // page lives inside it. Standalone links (Dashboard "/", admin hub "/admin")
    // belong to no group. Manual expand/collapse (closing siblings) is wired up
    // in JS — see the accordion handler in App.razor.
    // Each array mirrors one <details> group in the markup above, in the same order.
    private static readonly string[] MarketRoutes =
        { "/map", "/transactions", "/price-index", "/rental-index", "/mortgage" };
    private static readonly string[] EntitiesRoutes =
        { "/projects", "/developers", "/developers/scorecards", "/beneficial-ownership" };
    private static readonly string[] InsightsRoutes =
        { "/analytics", "/analytics/compare", "/benchmark", "/esg", "/greti" };
    private static readonly string[] WorkspaceRoutes =
        { "/watchlist", "/alerts", "/notifications" };
    private static readonly string[] ToolsRoutes =
        { "/ai-agent", "/api-portal" };
    private static readonly string[] AdminRiskRoutes =
        { "/admin/ewrs", "/admin/ewrs/alerts", "/admin/escrow", "/admin/audit" };
    private static readonly string[] AdminDevRoutes =
        { "/admin/developers", "/admin/cms" };

    // Segment-aware containment: the path is the route itself or a child of it.
    private bool GroupOpen(string[] routes) => routes.Any(r => IsUnder(_currentPath, r));

    private static bool IsUnder(string path, string route) =>
        string.Equals(path, route, StringComparison.OrdinalIgnoreCase) ||
        path.StartsWith(route + "/", StringComparison.OrdinalIgnoreCase);

    private bool MarketOpen    => GroupOpen(MarketRoutes);
    private bool EntitiesOpen  => GroupOpen(EntitiesRoutes);
    private bool InsightsOpen  => GroupOpen(InsightsRoutes);
    private bool ToolsOpen     => GroupOpen(ToolsRoutes);
    private bool AdminRiskOpen => GroupOpen(AdminRiskRoutes);
    private bool AdminDevOpen  => GroupOpen(AdminDevRoutes);

    // Every concrete link target in the sidebar. Declared after the group arrays
    // so the static initializer can fold them together (textual order matters).
    private static readonly string[] AllNavHrefs =
        new[] { "/", "/admin" }
            .Concat(MarketRoutes).Concat(EntitiesRoutes).Concat(InsightsRoutes)
            .Concat(WorkspaceRoutes).Concat(ToolsRoutes)
            .Concat(AdminRiskRoutes).Concat(AdminDevRoutes)
            .ToArray();

    private string _activeHref = "/";

    // Pick the longest href that contains the current path. "/" only matches the
    // root exactly; admin pages not surfaced in the sidebar (e.g. /admin/playbooks)
    // fall back to the next-longest match, which is the hub "/admin".
    private string ComputeActiveHref()
    {
        var best = "";
        foreach (var h in AllNavHrefs)
        {
            var matches = h == "/" ? _currentPath == "/" : IsUnder(_currentPath, h);
            if (matches && h.Length > best.Length) best = h;
        }
        return best;
    }

    private async Task ToggleSidebar() => await JS.InvokeVoidAsync("sidebarInterop.toggle");
    private async Task CloseSidebar()  => await JS.InvokeVoidAsync("sidebarInterop.close");

    // Schema.org organization block emitted on every page (RFP Section 20 —
    // machine-readable access). Investment-research crawlers pick up GRETI
    // sub-index signal even on anonymous landing.
    private static readonly Dictionary<string, object> OrganizationSchema = new()
    {
        ["name"]       = "Dubai Land Department",
        ["legalName"]  = "Dubai Land Department",
        ["url"]        = "https://dubailand.gov.ae",
        ["logo"]       = "https://iretp.dld.gov.ae/images/logos/dld-logo.png",
        ["areaServed"] = "Dubai, United Arab Emirates",
        ["sameAs"]     = new[] { "https://www.linkedin.com/company/dubailanddepartment" }
    };
}
