@page "/admin"
@rendermode InteractiveServer
@inject WebApiClient Api
@inject AdminApiClient AdminApi
@inject AdminFixtureService Fixture

<PageTitle>IRETP — Administration Hub</PageTitle>

<div class="container-fluid py-4">
    <ModuleBanner Icon="speedometer2"
                  Title="Administration Hub"
                  Subtitle="Operational overview plus the admin tools that have no dedicated sidebar entry. Every other admin surface now lives in the sidebar under Administration.">
        <ActionsContent>
            <span class="admin-env-badge"><span class="dot"></span> Live · DLD</span>
        </ActionsContent>
    </ModuleBanner>

    @* Tab strip — swap between the operational overview and the two admin tools
       that aren't surfaced in the sidebar. Tool panels are mounted only while
       their tab is active so their charts size correctly and dispose on switch. *@
    <ul class="nav nav-tabs admin-hub-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @TabClass("overview")" role="tab"
                    aria-selected="@(_tab == "overview")" @onclick='() => SetTab("overview")'>
                <i class="bi bi-speedometer2 me-1"></i> Overview
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @TabClass("playbooks")" role="tab"
                    aria-selected="@(_tab == "playbooks")" @onclick='() => SetTab("playbooks")'>
                <i class="bi bi-journal-check me-1"></i> EWRS Playbooks
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @TabClass("compare")" role="tab"
                    aria-selected="@(_tab == "compare")" @onclick='() => SetTab("compare")'>
                <i class="bi bi-bar-chart-steps me-1"></i> Developer Comparison
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @TabClass("ai-models")" role="tab"
                    aria-selected="@(_tab == "ai-models")" @onclick='() => SetTab("ai-models")'>
                <i class="bi bi-cpu me-1"></i> AI Models
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @TabClass("fabric")" role="tab"
                    aria-selected="@(_tab == "fabric")" @onclick='() => SetTab("fabric")'>
                <i class="bi bi-diagram-3 me-1"></i> Fabric / OneLake
            </button>
        </li>
    </ul>

    @if (_tab == "overview")
    {
        <div class="row g-3 admin-kpi">
            <div class="col-6 col-lg-3">
                <KpiCard Title="High-Risk Projects" Value="@K(_d?.TotalHighRiskProjects)" Icon="exclamation-triangle" Color="danger" />
            </div>
            <div class="col-6 col-lg-3">
                <KpiCard Title="Active Alerts" Value="@K(_d?.TotalActiveAlerts)" Icon="bell" Color="warning" />
            </div>
            <div class="col-6 col-lg-3">
                <KpiCard Title="Escrow Shortfalls" Value="@K(_d?.ProjectsWithEscrowShortfall)" Icon="safe2" Color="info" />
            </div>
            <div class="col-6 col-lg-3">
                <KpiCard Title="Unacknowledged" Value="@K(_d?.UnacknowledgedAlerts)" Icon="inbox" Color="primary" />
            </div>
        </div>
        <p class="text-muted small mt-3 mb-0">
            <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
            Risk &amp; Compliance and Developer Oversight have their own entries in the
            sidebar under <strong>Administration</strong>. The tabs above are the tools
            without a dedicated sidebar entry.
        </p>
    }
    else if (_tab == "playbooks")
    {
        <PlaybooksPanel />
    }
    else if (_tab == "compare")
    {
        <DeveloperComparisonPanel />
    }
    else if (_tab == "ai-models")
    {
        <AIModelsPanel />
    }
    else if (_tab == "fabric")
    {
        <FabricStatusPanel />
    }
</div>

@code {
    private EwrsDashboardData? _d;
    private string _tab = "overview";

    private string TabClass(string tab) => _tab == tab ? "active" : "";
    private void SetTab(string tab) => _tab = tab;

    protected override async Task OnInitializedAsync()
    {
        // Same resilient pattern as the EWRS page: try the AdminAPI, fall back to
        // seeded fixtures so the overview always shows live operational counts.
        try
        {
            var login = await Api.LoginAsync("admin@dld.gov.ae", "Admin@DLD2026!");
            if (login != null) AdminApi.SetToken(login.AccessToken);
            _d = await AdminApi.GetEwrsDashboardAsync();
        }
        catch { /* backend offline — fall through */ }
        _d ??= Fixture.EwrsDashboard();
    }

    private static string K(int? v) => v?.ToString("N0") ?? "—";
}
