@page "/admin/ai-models"
@rendermode InteractiveServer
@inject AdminApiClient AdminApi
@inject WebApiClient Api

<PageTitle>IRETP — AI model status</PageTitle>

<div class="container-fluid py-4">
    <ModuleBanner Icon="cpu"
                  Title="AI model performance"
                  Subtitle="Model Performance Transparency (RFP Section 5.3). Live snapshot of every configured AI model — active status, throughput, latency, and fallback conditions.">
        <ActionsContent>
            <span class="admin-env-badge"><span class="dot"></span> Live</span>
            <button class="btn btn-outline-primary btn-sm" @onclick="Refresh">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </ActionsContent>
    </ModuleBanner>

    @if (_loading)
    {
        <SkeletonTable Rows="6" Columns="5" WithCard="true" />
    }
    else if (_models is null)
    {
        <NetworkError Service="AI model status" Detail="Ensure the Admin API is running and you are signed in as a Supervisor or System Administrator." />
    }
    else if (_models.Count == 0)
    {
        <EmptyState Icon="cpu" Title="No AI activity yet"
                    Message="Invoke the AI Agent once to see model metrics populate." />
    }
    else
    {
        <!-- Summary cards -->
        <div class="row g-3 mb-4 admin-kpi">
            <div class="col-6 col-lg-3">
                <KpiCard Title="Configured models" Value="@_models.Count.ToString("N0")" Icon="cpu" Color="primary" />
            </div>
            <div class="col-6 col-lg-3">
                <KpiCard Title="Active" Value="@_models.Count(m => m.Active).ToString("N0")" Icon="check-circle" Color="success" />
            </div>
            <div class="col-6 col-lg-3">
                <KpiCard Title="In fallback" Value="@_models.Count(m => m.FallbackActive).ToString("N0")" Icon="arrow-repeat" Color="warning" />
            </div>
            <div class="col-6 col-lg-3">
                <KpiCard Title="Successful calls" Value="@_models.Sum(m => m.SuccessCalls).ToString("N0")" Icon="check2-all" Color="info" />
            </div>
        </div>

        <!-- Model table -->
        <div class="admin-card">
            <div class="admin-card-head"><h2 class="admin-card-title"><i class="bi bi-list-ul"></i> Model roster</h2></div>
            <div class="table-responsive admin-scroll">
                <table class="table table-sm mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Model</th>
                            <th>Version</th>
                            <th>Status</th>
                            <th class="text-end">Success</th>
                            <th class="text-end">Failed</th>
                            <th class="text-end">Avg latency</th>
                            <th class="text-end">P95 latency</th>
                            <th>Last called</th>
                            <th>Last error</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _models)
                        {
                            <tr>
                                <td class="fw-semibold">@m.Name</td>
                                <td class="small text-muted">@m.Version</td>
                                <td>
                                    @if (m.FallbackActive)
                                    {
                                        <span class="badge bg-warning text-dark">Fallback</span>
                                    }
                                    else if (m.Active)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">@m.SuccessCalls.ToString("N0")</td>
                                <td class="text-end">
                                    @if (m.FailedCalls > 0)
                                    {
                                        <span class="text-danger fw-bold">@m.FailedCalls.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">0</span>
                                    }
                                </td>
                                <td class="text-end">@m.AverageLatencyMs.ToString("N0") ms</td>
                                <td class="text-end">@m.P95LatencyMs.ToString("N0") ms</td>
                                <td class="small">@(m.LastCalledAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</td>
                                <td class="small text-danger">@(m.LastError ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<AIModelStatusItem>? _models;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        // Self-authenticate as the seeded admin so the gated AdminAPI calls
        // carry a bearer token — same pattern as the other internal pages.
        try
        {
            var login = await Api.LoginAsync("admin@dld.gov.ae", "Admin@DLD2026!");
            if (login != null) AdminApi.SetToken(login.AccessToken);
        }
        catch { /* backend offline — page shows the NetworkError state */ }

        await Refresh();
    }

    private async Task Refresh()
    {
        _loading = true;
        try
        {
            _models = await AdminApi.GetAIModelStatusAsync();
        }
        finally
        {
            _loading = false;
        }
    }
}
