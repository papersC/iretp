@page "/admin/playbooks"
@rendermode InteractiveServer
@inject AdminApiClient AdminApi
@inject WebApiClient Api

<PageTitle>IRETP — EWRS playbooks</PageTitle>

<div class="container-fluid py-4">
    <ModuleBanner Icon="journal-check"
                  Title="EWRS playbooks"
                  Subtitle="Standard operating procedures attached to each risk indicator (RFP Section 8.3). Editing a playbook updates the default checklist applied to all newly-raised alerts of that type. Existing alerts retain the checklist they were raised with.">
        <ActionsContent>
            @if (!_loading && _playbooks.Count > 0)
            {
                <span class="admin-env-badge"><span class="dot"></span> @_playbooks.Count playbooks</span>
            }
            <button class="btn btn-outline-primary btn-sm" @onclick="Refresh">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </ActionsContent>
    </ModuleBanner>

    @if (_loading)
    {
        <SkeletonTable Rows="5" Columns="3" WithCard="true" />
    }
    else if (_playbooks.Count == 0)
    {
        <NetworkError Service="Playbooks" Detail="Ensure the Admin API is running and you are signed in as a Supervisor or System Administrator." />
    }
    else
    {
        <div class="accordion" id="playbookAccordion">
            @foreach (var pb in _playbooks)
            {
                var key = pb.ThresholdId.ToString("N");
                <div class="accordion-item">
                    <h2 class="accordion-header" id="head-@key">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                data-bs-target="#body-@key" aria-expanded="false">
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-bookmark-check text-primary"></i>
                                <strong>@pb.IndicatorName</strong>
                                <span class="badge bg-light text-dark border">@pb.Steps.Count step(s)</span>
                            </div>
                        </button>
                    </h2>
                    <div id="body-@key" class="accordion-collapse collapse" data-bs-parent="#playbookAccordion">
                        <div class="accordion-body">
                            <div class="small text-muted mb-2">Indicator key: <code>@pb.IndicatorKey</code></div>
                            <ol class="mb-3">
                                @for (var i = 0; i < _editing[pb.ThresholdId].Count; i++)
                                {
                                    var idx = i;
                                    <li class="d-flex align-items-start gap-2 mb-2">
                                        <input class="form-control form-control-sm"
                                               value="@_editing[pb.ThresholdId][idx]"
                                               @onchange='(e) => UpdateStep(pb.ThresholdId, idx, e.Value?.ToString() ?? string.Empty)' />
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => RemoveStep(pb.ThresholdId, idx)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </li>
                                }
                            </ol>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => AddStep(pb.ThresholdId)">
                                    <i class="bi bi-plus-lg"></i> Add step
                                </button>
                                <button class="btn btn-primary btn-sm" @onclick="() => SavePlaybook(pb.ThresholdId)"
                                        disabled="@(!_dirty.Contains(pb.ThresholdId))">
                                    <i class="bi bi-save"></i> Save
                                </button>
                                @if (_savedAt.TryGetValue(pb.ThresholdId, out var ts))
                                {
                                    <span class="small text-success align-self-center">Saved @ts.ToString("HH:mm:ss")</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PlaybookDto> _playbooks = new();
    private readonly Dictionary<Guid, List<string>> _editing = new();
    private readonly HashSet<Guid> _dirty = new();
    private readonly Dictionary<Guid, DateTime> _savedAt = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var login = await Api.LoginAsync("admin@dld.gov.ae", "Admin@DLD2026!");
            if (login != null) AdminApi.SetToken(login.AccessToken);
        }
        catch { /* dev-only convenience — ignore when backend is offline */ }

        await Refresh();
    }

    private async Task Refresh()
    {
        _loading = true;
        try
        {
            var result = await AdminApi.GetPlaybooksAsync();
            _playbooks = result ?? new();
            _editing.Clear();
            _dirty.Clear();
            foreach (var pb in _playbooks)
            {
                _editing[pb.ThresholdId] = pb.Steps.ToList();
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private void UpdateStep(Guid id, int index, string value)
    {
        if (!_editing.TryGetValue(id, out var list)) return;
        if (index < 0 || index >= list.Count) return;
        list[index] = value;
        _dirty.Add(id);
    }

    private void AddStep(Guid id)
    {
        if (!_editing.TryGetValue(id, out var list)) return;
        list.Add("New step");
        _dirty.Add(id);
    }

    private void RemoveStep(Guid id, int index)
    {
        if (!_editing.TryGetValue(id, out var list)) return;
        if (index < 0 || index >= list.Count) return;
        list.RemoveAt(index);
        _dirty.Add(id);
    }

    private async Task SavePlaybook(Guid id)
    {
        if (!_editing.TryGetValue(id, out var list)) return;
        var ok = await AdminApi.UpdatePlaybookAsync(id, list);
        if (ok)
        {
            _dirty.Remove(id);
            _savedAt[id] = DateTime.Now;
        }
    }
}
