@page "/admin/cms"
@rendermode InteractiveServer
@inject CmsContentStore Store
@inject UiStateService Ui
@inject WebApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>IRETP - CMS Admin</PageTitle>

<div class="container-fluid py-4">
<ModuleBanner Icon="file-earmark-text"
              Title="Content Management"
              Subtitle="Edit banners, KPI callouts, legends, and disclaimers. Staged changes require Publish."
              ButtonText="New content"
              ButtonIcon="plus-lg"
              OnButtonClick="OpenNew" />

<div class="row g-3">
    <div class="col-lg-4">
        <div class="admin-card h-100">
            <div class="admin-card-head">
                <h2 class="admin-card-title"><i class="bi bi-collection"></i> Content items</h2>
                <span class="badge text-bg-secondary">@Store.All().Count</span>
            </div>
            <div class="list-group list-group-flush" style="max-height: 540px; overflow-y:auto;">
                @foreach (var c in Store.All().OrderBy(c => c.PageKey).ThenBy(c => c.SectionKey))
                {
                    var active = _editing?.Id == c.Id;
                    <button type="button" class="list-group-item list-group-item-action @(active ? "active" : "")"
                            @onclick="() => Select(c)">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-semibold">@c.PageKey / @c.SectionKey</div>
                                <div class="small @(active ? "text-white-50" : "text-muted")">
                                    @c.ContentType · v@c.Version
                                </div>
                            </div>
                            @if (c.IsPublished)
                            {
                                <span class="badge bg-success">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Draft</span>
                            }
                        </div>
                    </button>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        @if (_editing == null)
        {
            <div class="admin-card h-100">
                <div class="admin-card-body text-center text-muted py-5">
                    <i class="bi bi-arrow-left-circle fs-1"></i>
                    <div class="mt-3">Select a content item to edit, or create a new one.</div>
                </div>
            </div>
        }
        else
        {
            <div class="admin-card">
                <div class="admin-card-head">
                    <h2 class="admin-card-title"><i class="bi bi-pencil-square"></i> @(_editing.Id == Guid.Empty ? "New content" : $"Editing: {_editing.PageKey}/{_editing.SectionKey}")</h2>
                    <div class="d-flex gap-2">
                        @if (_editing.Id != Guid.Empty)
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="OpenVersionHistory">
                                <i class="bi bi-clock-history"></i> History
                            </button>
                        }
                        @if (_editing.Id != Guid.Empty && !_editing.IsPublished)
                        {
                            <button class="btn btn-sm btn-outline-success" @onclick="Publish">
                                <i class="bi bi-send"></i> Publish
                            </button>
                        }
                        @if (_editing.Id != Guid.Empty)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteEditing">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        }
                    </div>
                </div>
                <div class="admin-card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="page-key" class="form-label">Page key</label>
                            <input id="page-key" type="text" class="form-control" @bind="_editing.PageKey" placeholder="e.g. home, map, transactions" />
                        </div>
                        <div class="col-md-4">
                            <label for="section-key" class="form-label">Section key</label>
                            <input id="section-key" type="text" class="form-control" @bind="_editing.SectionKey" placeholder="e.g. hero-banner" />
                        </div>
                        <div class="col-md-2">
                            <label for="type" class="form-label">Type</label>
                            <select id="type" class="form-select" @bind="_editing.ContentType">
                                <option>RichText</option>
                                <option>Banner</option>
                                <option>KPI</option>
                                <option>Annotation</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="order" class="form-label">Order</label>
                            <input id="order" type="number" class="form-control" @bind="_editing.SortOrder" />
                        </div>
                        <div class="col-md-6">
                            <label for="english-body" class="form-label">English body</label>
                            <textarea id="english-body" class="form-control" rows="6" @bind="_editing.ContentEn"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label for="arabic-body" class="form-label">Arabic body</label>
                            <textarea id="arabic-body" class="form-control" rows="6" dir="rtl" @bind="_editing.ContentAr"></textarea>
                        </div>
                    </div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <div class="small text-muted">
                        Last updated @_editing.UpdatedAt.ToString("dd MMM yyyy HH:mm") by @_editing.UpdatedBy · v@_editing.Version
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveDraft">
                            <i class="bi bi-save"></i> Save draft
                        </button>
                    </div>
                </div>
            </div>

            <div class="admin-card mt-3">
                <div class="admin-card-head"><h2 class="admin-card-title"><i class="bi bi-eye"></i> Preview</h2></div>
                <div class="admin-card-body">
                    <ul class="nav nav-tabs mb-3">
                        <li class="nav-item">
                            <button type="button" class="nav-link @(_preview == "en" ? "active" : "")" @onclick='() => _preview = "en"'>English</button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link @(_preview == "ar" ? "active" : "")" @onclick='() => _preview = "ar"'>العربية</button>
                        </li>
                    </ul>
                    <div class="p-3 border rounded" dir="@(_preview == "ar" ? "rtl" : "ltr")">
                        @_preview.ToString().ToUpper() ·
                        @((_preview == "ar" ? _editing.ContentAr : _editing.ContentEn))
                    </div>
                </div>
            </div>
        }
    </div>
</div>
</div>

@if (_showHistory && _editing != null)
{
    <div class="modal d-block" style="background:rgba(0,0,0,.4);" @onclick="CloseHistory">
        <div class="modal-dialog modal-dialog-centered modal-xl" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-clock-history me-2"></i>Version history — @_editing.PageKey / @_editing.SectionKey
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseHistory"></button>
                </div>
                <div class="modal-body">
                    @if (_historyLoading)
                    {
                        <SkeletonTable Rows="4" Columns="3" />
                    }
                    else if (_versions.Count == 0)
                    {
                        <div class="alert alert-info mb-0">
                            No backend history recorded for this content yet. Save a draft while the
                            Admin API is reachable to populate the version log.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive" style="max-height: 500px;">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Ver</th>
                                        <th>Type</th>
                                        <th>Summary</th>
                                        <th>By</th>
                                        <th>When</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in _versions)
                                    {
                                        <tr>
                                            <td class="fw-semibold">v@v.VersionNumber</td>
                                            <td>@ChangeBadge(v.ChangeType)</td>
                                            <td>@(v.Summary ?? "—")</td>
                                            <td class="small">@(v.CreatedBy ?? "—")</td>
                                            <td class="small text-muted">@v.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary me-1"
                                                        @onclick="() => SharePreview(v.Id)">
                                                    <i class="bi bi-share"></i> Preview link
                                                </button>
                                                <button class="btn btn-sm btn-outline-warning"
                                                        @onclick="() => Rollback(v.Id, v.VersionNumber)">
                                                    <i class="bi bi-arrow-counterclockwise"></i> Rollback
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_lastPreviewUrl))
                    {
                        <div class="alert alert-success d-flex justify-content-between align-items-center mt-3 mb-0">
                            <div>
                                <div class="fw-semibold">Preview link ready</div>
                                <div class="small text-muted">Expires @_lastPreviewExpiry?.ToString("yyyy-MM-dd HH:mm")</div>
                                <code class="small">@_lastPreviewUrl</code>
                            </div>
                            <button class="btn btn-sm btn-outline-primary" @onclick="CopyPreviewUrl">
                                <i class="bi bi-clipboard"></i> Copy
                            </button>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseHistory">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private CmsContentStore.Content? _editing;
    private string _preview = "en";

    // Version history modal
    private bool _showHistory;
    private bool _historyLoading;
    private List<CmsVersionDto> _versions = new();
    private string? _lastPreviewUrl;
    private DateTime? _lastPreviewExpiry;

    protected override void OnInitialized() => Store.OnChange += OnChange;
    public void Dispose() => Store.OnChange -= OnChange;
    private void OnChange() => InvokeAsync(StateHasChanged);

    private void Select(CmsContentStore.Content c)
    {
        _editing = new CmsContentStore.Content
        {
            Id = c.Id,
            PageKey = c.PageKey,
            SectionKey = c.SectionKey,
            ContentType = c.ContentType,
            ContentEn = c.ContentEn,
            ContentAr = c.ContentAr,
            SortOrder = c.SortOrder,
            IsPublished = c.IsPublished,
            PublishedAt = c.PublishedAt,
            Version = c.Version,
            UpdatedAt = c.UpdatedAt,
            UpdatedBy = c.UpdatedBy,
        };
    }

    private void OpenNew()
    {
        _editing = new CmsContentStore.Content
        {
            Id = Guid.Empty,
            PageKey = "home",
            SectionKey = "section-" + DateTime.Now.Ticks.ToString()[^4..],
            ContentType = "RichText",
            ContentEn = "",
            ContentAr = "",
            SortOrder = 10,
            IsPublished = false,
            Version = 0,
        };
    }

    private void Cancel() => _editing = null;

    private void SaveDraft()
    {
        if (_editing == null) return;
        if (_editing.Id == Guid.Empty)
            _editing = new CmsContentStore.Content
            {
                PageKey = _editing.PageKey,
                SectionKey = _editing.SectionKey,
                ContentType = _editing.ContentType,
                ContentEn = _editing.ContentEn,
                ContentAr = _editing.ContentAr,
                SortOrder = _editing.SortOrder,
                IsPublished = false,
            };
        Store.Upsert(_editing, "dld-editor");
    }

    private void Publish()
    {
        if (_editing?.Id == null || _editing.Id == Guid.Empty) return;
        Store.Publish(_editing.Id, "dld-editor");
        var refreshed = Store.Find(_editing.Id);
        if (refreshed != null) Select(refreshed);
    }

    private void DeleteEditing()
    {
        if (_editing?.Id == null || _editing.Id == Guid.Empty) return;
        Store.Delete(_editing.Id);
        _editing = null;
    }

    // -----------------------------------------------------------------------
    // Version history + preview workflow (RFP FR002)
    // -----------------------------------------------------------------------
    private async Task OpenVersionHistory()
    {
        if (_editing is null || _editing.Id == Guid.Empty) return;
        _showHistory = true;
        _historyLoading = true;
        _lastPreviewUrl = null;
        _versions = new();

        try
        {
            var result = await Api.GetCmsVersionsAsync(_editing.Id);
            _versions = result ?? new();
        }
        finally
        {
            _historyLoading = false;
        }
    }

    private void CloseHistory()
    {
        _showHistory = false;
        _lastPreviewUrl = null;
    }

    private async Task SharePreview(Guid versionId)
    {
        var link = await Api.CreateCmsPreviewLinkAsync(versionId);
        if (link is null)
        {
            await JS.InvokeVoidAsync("alert",
                "Could not generate a preview link — make sure the Admin API is reachable.");
            return;
        }
        _lastPreviewUrl = Nav.ToAbsoluteUri($"/cms/preview/{link.Token}").ToString();
        _lastPreviewExpiry = link.ExpiresAt;
    }

    private async Task CopyPreviewUrl()
    {
        if (string.IsNullOrEmpty(_lastPreviewUrl)) return;
        try { await JS.InvokeVoidAsync("iretpDownload.copyToClipboard", _lastPreviewUrl); }
        catch { /* non-fatal */ }
    }

    private async Task Rollback(Guid versionId, int versionNumber)
    {
        if (_editing is null) return;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Roll back {_editing.PageKey}/{_editing.SectionKey} to v{versionNumber}? " +
            "The rollback creates a new draft — you'll still need to click Publish to push it live.");
        if (!confirmed) return;

        var ok = await Api.RollbackCmsVersionAsync(_editing.Id, versionId);
        if (!ok)
        {
            await JS.InvokeVoidAsync("alert", "Rollback failed. The version may have been removed.");
            return;
        }

        // Reload history and local draft state
        _versions = (await Api.GetCmsVersionsAsync(_editing.Id)) ?? new();
        _showHistory = false;
        await JS.InvokeVoidAsync("alert",
            $"Rolled back to v{versionNumber}. The new draft is ready — click Publish when approved.");
    }

    private static RenderFragment ChangeBadge(string changeType) => __b =>
    {
        var (cls, label) = changeType switch
        {
            "Published" => ("bg-success", "Published"),
            "Rollback" => ("bg-warning text-dark", "Rollback"),
            _ => ("bg-secondary", "Draft")
        };
        __b.OpenElement(0, "span");
        __b.AddAttribute(1, "class", $"badge {cls}");
        __b.AddContent(2, label);
        __b.CloseElement();
    };
}
