@page "/auth/register"
@rendermode InteractiveServer
@inject WebApiClient Api
@inject AdminApiClient AdminApi
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Register</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold" style="color: var(--primary-color);">Create Account</h3>
                        <p class="text-muted">Join the IRETP Platform</p>
                    </div>

                    @if (_error != null)   { <div class="alert alert-danger">@_error</div> }
                    @if (_message != null) { <div class="alert alert-info">@_message</div> }

                    <div class="row mb-3">
                        <div class="col"><input type="text" class="form-control" @bind="_firstName" placeholder="First name" aria-label="First name" /></div>
                        <div class="col"><input type="text" class="form-control" @bind="_lastName"  placeholder="Last name" aria-label="Last name" /></div>
                    </div>
                    <div class="mb-3">
                        <input type="email" class="form-control" @bind="_email" placeholder="Email" aria-label="Email" />
                    </div>
                    <div class="mb-3">
                        <input type="password" class="form-control" @bind="_password" placeholder="Password (min 8 chars)" aria-label="Password (min 8 chars)" />
                    </div>
                    <button class="btn btn-primary w-100 py-2" @onclick="RegisterAsync" disabled="@_submitting">
                        @if (_submitting) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        Register and sign in
                    </button>
                    <div class="text-center mt-3">
                        <a href="/auth/login">Already have an account? Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _firstName = "", _lastName = "", _email = "", _password = "";
    private string? _error;
    private string? _message;
    private bool _submitting;

    private async Task RegisterAsync()
    {
        _error = null; _message = null; _submitting = true;

        if (string.IsNullOrWhiteSpace(_email) || _password.Length < 8 ||
            string.IsNullOrWhiteSpace(_firstName) || string.IsNullOrWhiteSpace(_lastName))
        {
            _error = "Please fill in all fields. Password must be at least 8 characters.";
            _submitting = false;
            return;
        }

        string? token = null;
        string? displayName = $"{_firstName} {_lastName}".Trim();
        try
        {
            var registered = await Api.RegisterAsync(_email, _password, _firstName, _lastName);
            if (registered)
            {
                var login = await Api.LoginAsync(_email, _password);
                if (login != null) token = login.AccessToken;
            }
            else
            {
                _error = "Registration rejected. The email may already be in use.";
            }
        }
        catch
        {
            // Backend offline — accept the registration in demo mode so the user
            // can still evaluate the full portal experience.
            token = "demo-offline-" + Guid.NewGuid().ToString("n")[..12];
            _message = "Backend offline — signed you in with a demo session.";
        }

        if (token != null)
        {
            Api.SetToken(token);
            AdminApi.SetToken(token);
            Auth.SetToken(token, _email, displayName);
            try { await JS.InvokeVoidAsync("iretpUi.setSessionCookie", Auth.Encode()); } catch { }
            Nav.NavigateTo("/", forceLoad: true);
            return;
        }

        _submitting = false;
    }
}
