@*
    Standardised "no data yet" / empty-collection placeholder.

    Replaces the variants of `<div class="alert alert-info">No X yet…</div>`
    with a friendlier, icon-led empty state. ChildContent slot lets pages
    render an optional CTA button below the message.

    Usage:
        <EmptyState Icon="bookmark-star" Title="No watchlist items yet"
                    Message="Follow projects, zones, or developers to start receiving alerts." />

        <EmptyState Icon="inbox" Title="Inbox zero" Message="No notifications right now.">
            <button class="btn btn-sm btn-outline-primary">Configure alerts</button>
        </EmptyState>
*@

@code {
    [Parameter] public string Icon { get; set; } = "inbox";
    [Parameter] public string Title { get; set; } = "Nothing here yet";
    [Parameter] public string? Message { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}

<div class="text-center py-5">
    <div class="mb-3" style="display:inline-flex;width:64px;height:64px;border-radius:50%;background:rgba(var(--primary-color-rgb), .08);color:var(--primary-color);align-items:center;justify-content:center;">
        <i class="bi bi-@Icon" style="font-size:1.75rem;" aria-hidden="true"></i>
    </div>
    <h2 class="mb-1" style="font-size: var(--fs-base); font-weight: 600;">@Title</h2>
    @if (!string.IsNullOrEmpty(Message))
    {
        <p class="text-muted mb-3" style="max-width: 420px; margin-left: auto; margin-right: auto;">@Message</p>
    }
    @if (ChildContent is not null)
    {
        <div class="mt-2">@ChildContent</div>
    }
</div>
