@*
    Loading-state placeholder for a row of KPI cards. Mirrors the
    `<div class="row g-3"><div class="col-…"><div class="card">…</div></div></div>`
    pattern used across Dashboard, Mortgage, EwrsDashboard, etc.

    Each placeholder card has three stacked skeleton bars: label / value / hint.
    Uses Bootstrap responsive cols by default (50% mobile → 33% tablet → ~25% desktop).

    Usage:
        <SkeletonKpiGrid Count="4" />
        <SkeletonKpiGrid Count="5" ColClass="col-6 col-md-4 col-xl" />
*@

@code {
    [Parameter] public int Count { get; set; } = 4;
    [Parameter] public string Class { get; set; } = "row g-3 mb-3";
    [Parameter] public string ColClass { get; set; } = "col-6 col-md-4 col-xl-3";
}

<div class="@Class" aria-busy="true" aria-label="Loading KPIs">
    @for (int i = 0; i < Count; i++)
    {
        <div class="@ColClass">
            <div class="card shadow-sm p-3 h-100">
                <Skeleton Width="60%" Height=".75rem" />
                <div class="my-2"><Skeleton Width="40%" Height="1.75rem" /></div>
                <Skeleton Width="80%" Height=".75rem" />
            </div>
        </div>
    }
</div>
