@inject IRETP.Web.Services.UiStateService Ui
<!DOCTYPE html>
<html lang="@Ui.Language" dir="@(Ui.IsRtl ? "rtl" : "ltr")">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Integrated Real Estate Transparency Platform - Dubai Land Department" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Cairo:wght@300;400;500;600;700&display=swap" />
    @* Design-system Arabic typeface — IBM Plex Sans Arabic (ESEMS / ejraa360 stack). *@
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    @if (Ui.IsRtl)
    {
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    }
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" />
    @* Corporate-blue design system, ported from ESEMS / ejraa360. Loaded BEFORE
       app.css so DLD-green brand overrides in app.css win the cascade. *@
    <link rel="stylesheet" href="@Assets["css/material-design-3.css"]" />
    <link rel="stylesheet" href="@Assets["css/design-system.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["IRETP.Web.styles.css"]" />
    <link rel="stylesheet" href="css/accessibility.css" />
    <link rel="stylesheet" href="css/admin.css?v=3" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <!-- Open Graph / Twitter card (RFP 3.1 — SEO for international investors) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Dubai Land Department — IRETP" />
    <meta property="og:title" content="Integrated Real Estate Transparency Platform" />
    <meta property="og:description" content="Live Dubai real-estate market data: transactions, price index, rental yield, developer rating. Source: Dubai Land Department." />
    <meta property="og:locale" content="@Ui.Language" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="IRETP — Dubai Land Department" />
    <meta name="twitter:description" content="The authoritative source for Dubai real-estate transparency." />
    <HeadOutlet />
</head>

<body class="@(Ui.IsRtl ? "iretp-rtl" : "iretp-ltr")">
    <Routes />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
    <script src="js/chart-interop.js"></script>
    <script src="js/map-interop.js"></script>
    <script src="js/dubai-areas-geo.js?v=6"></script>
    <script src="js/dld-map-interop.js?v=4"></script>
    <script src="js/download-interop.js"></script>
    <script src="js/signalr-notifications.js"></script>
    <script src="js/inactivity-watch.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script>
        // Sidebar toggle
        window.sidebarInterop = {
            toggle: function () {
                var sb = document.getElementById('app-sidebar');
                var ov = document.getElementById('sidebarOverlay');
                if (!sb) return;
                if (window.innerWidth < 992) {
                    sb.classList.toggle('open');
                    if (ov) ov.classList.toggle('active');
                } else {
                    sb.classList.toggle('collapsed');
                }
            },
            close: function () {
                var sb = document.getElementById('app-sidebar');
                var ov = document.getElementById('sidebarOverlay');
                if (sb) sb.classList.remove('open');
                if (ov) ov.classList.remove('active');
            }
        };

        // Accordion behaviour for the collapsible sidebar groups: opening one
        // group collapses the others. `toggle` does not bubble, so we listen in
        // the capture phase on document — this survives enhanced navigations
        // because the listener lives on document, not the (re-rendered) sidebar.
        document.addEventListener('toggle', function (e) {
            var d = e.target;
            if (d && d.tagName === 'DETAILS' && d.classList.contains('nav-section') && d.open) {
                document.querySelectorAll('.sidebar details.nav-section').forEach(function (other) {
                    if (other !== d) other.open = false;
                });
            }
        }, true);
    </script>
</body>

</html>
